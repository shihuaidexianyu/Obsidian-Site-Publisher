{
  "name": "obsidian-site-publisher",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.6.0",
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "build:native-cli": "node ./scripts/build-native-cli.mjs",
    "build:obsidian-plugin": "node ./apps/obsidian-plugin/scripts/build-plugin.mjs",
    "build:release": "node ./scripts/build-release.mjs",
    "lint": "eslint . --ext .ts --max-warnings=0",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "corepack pnpm lint && corepack pnpm test && corepack pnpm build"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^8.30.0",
    "@typescript-eslint/parser": "^8.30.0",
    "esbuild": "^0.27.0",
    "eslint": "^9.24.0",
    "globals": "^16.0.0",
    "postject": "1.0.0-alpha.6",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1",
    "yazl": "^3.3.1",
    "zod": "^3.24.2"
  }
}
